+        assert_eq!(detail.intent_id, "intent_missing");
+        assert_eq!(detail.intent_title, None);
+        assert_eq!(detail.decision_id.as_deref(), Some("dec_missing"));
+        assert_eq!(detail.decision_status, None);
+        assert_eq!(detail.check_status, None);
+    }
+
+    #[test]
+    fn provenance_detail_without_optional_ids_only_resolves_title() {
+        let temp = tempfile::tempdir().expect("temp dir");
+        let root = temp.path();
