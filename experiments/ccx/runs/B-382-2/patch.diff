+/// NER-382 drift guard for `attempt attach`: compare the attempt's workspace dir
+/// against the content ref recorded when it was last materialized. Returns
+/// `Some(drifted_paths)` (name-level, workspace-relative) when the dir was edited
+/// since, `None` when it matches, was never materialized (no recorded ref — e.g.
+/// the git backend, which does not materialize workspace dirs), or was removed
+/// wholesale (re-materialization recreates it without losing edits). The check
+/// snapshots the workspace with the same policy exclusions as materialization, so
+/// policy-excluded paths (marker file, secret-risk names) never read as drift.
+pub(crate) fn detect_attempt_workspace_drift(
+    cwd: &Path,
+    attempt_id: &str,
+) -> anyhow::Result<Option<Vec<String>>> {
+    let Some(recorded_ref) = forge_store::attempt_workspace_materialized_ref(cwd, attempt_id)?
+    else {
+        return Ok(None);
+    };
+    let workspace = forge_store::attempt_workspace_path(cwd, attempt_id)?;
+    if !workspace.is_dir() {
+        return Ok(None);
+    }
+    let repo_root = forge_store::repository_root_path(cwd)?;
+    let actual =
+        forge_content_native::snapshot_worktree_into_store_excluding(&repo_root, &workspace, &[])?;
+    if actual.content_ref == recorded_ref {
+        return Ok(None);
+    }
+    let diff = diff_content_refs(
+        &repo_root,
+        &recorded_ref,
+        &actual.content_ref,
+        native_diff_options(false),
+    )?;
+    Ok(Some(
+        diff.files.iter().map(|file| file.path.clone()).collect(),
+    ))
+}
