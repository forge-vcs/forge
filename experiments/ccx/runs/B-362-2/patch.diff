+            attribute_file_lines(&store, &[("c1".to_string(), root.clone())], "src").unwrap_err();
+        assert!(directory.to_string().contains("directory"));
+
+        let binary =
+            attribute_file_lines(&store, &[("c1".to_string(), root)], "blob.bin").unwrap_err();
+        assert!(binary.to_string().contains("binary"));
+    }
 }
